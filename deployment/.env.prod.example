# Production Environment Variables

# IMPORTANT: Change all sensitive values before deploying!

# Database
DB_USER=wxlingua_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=wxlingua
DB_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend
BACKEND_PORT=3000
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM_STRING
CORS_ORIGIN=https://yourdomain.com

# S3 Storage
S3_REGION=ap-southeast-1
S3_BUCKET=wxlingua-prod
S3_ENDPOINT=
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-southeast-1.amazonaws.com
S3_FORCE_PATH_STYLE=false

# Frontend
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Version
VERSION=1.0.0

# Environment
NODE_ENV=production
