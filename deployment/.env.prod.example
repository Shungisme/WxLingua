# Production Environment Variables

# IMPORTANT: Change all sensitive values before deploying!

# Database
DB_USER=wxlingua_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=wxlingua
DB_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend
BACKEND_PORT=3000
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARACTERS_RANDOM_STRING
CORS_ORIGIN=https://yourdomain.com

# Frontend
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Version
VERSION=0.0.2

# Environment
NODE_ENV=production

# SSL
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ─── Google Drive Backup ──────────────────────────────────────
# rclone remote name (must match [section] name in rclone.conf)
GDRIVE_REMOTE=gdrive

# Destination folder path inside Google Drive
GDRIVE_FOLDER=WxLingua/backups

# Path to Google Drive service account JSON (Method A)
# Download from Google Cloud Console → IAM → Service Accounts → Keys
GDRIVE_SA_FILE=./backup/gdrive-sa.json

# Days to keep local backup files (default: 7)
LOCAL_RETENTION_DAYS=7

# Number of most-recent backups to keep on Google Drive (0 = keep all)
GDRIVE_RETENTION_COUNT=30
