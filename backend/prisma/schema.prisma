 generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Users
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  avatar    String?
  role      Role     @default(USER)
  
  words          UserWord[]
  decks          Deck[]
  resetTokens    PasswordResetToken[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

// 1.1 Password Reset Tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   // Hashed reset code
  expiresAt DateTime
  used      Boolean  @default(false)
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}

// 2. Radicals (214 Kangxi + extended)
model Radical {
  id          String   @id @default(cuid())
  char        String   @unique // '氵', '木', '口', '宀'
  variant     String   // 'phồn thể', 'giản thể', 'chung'
  strokeCount Int      // 1-17
  meaning     Json     // {"vi": "nước", "en": "water", "zh": "氵部"}
  imageUrl    String?  // Stroke diagram PNG/SVG
  frequency   Int      // Usage count
  
  words       WordRadical[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 3. Words (Multi-language)
model Word {
  id            String        @id @default(cuid())
  languageCode  String        // 'zh-TW', 'en', 'ja', 'ko'
  word          String        @unique // '學', 'learn', '学ぶ'
  frequency     Int?          // Study priority (1-1000)
  level         String?       // A1, A2, N5, JLPT...
  
  // Language-specific metadata
  metadata      Json?         // {"pinyin": "xué", "phonetic": "/lɜːrn/"}
  
  // Audio pronunciation
  audioUrl      String?       // "/audio/zh/xue.mp3" or S3 URL
  
  // Relations
  wordRadicals  WordRadical[]
  userWords     UserWord[]
  deckCards     DeckCard[]    // deck cards sourced from this word
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// 4. WordRadical (Many-to-Many: Word ↔ Radicals)
model WordRadical {
  id        String @id @default(cuid())
  wordId    String
  radicalId String
  position  Int    @default(0) // Order: Left->Right, Top->Bottom
  
  word     Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  radical  Radical  @relation(fields: [radicalId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([wordId, radicalId])
}

// 5. UserWord (Spaced Repetition Progress)
model UserWord {
  id           String    @id @default(cuid())
  userId       String
  wordId       String
  progress     Float     @default(0)    // 0-1 mastery %
  streak       Int       @default(0)    // Consecutive correct reviews
  nextReview   DateTime  @default(now()) // Scheduled next review date
  efactor      Float     @default(2.5)  // Legacy E-Factor (kept for migration compat)

  // FSRS scheduling fields
  stability    Float     @default(0)    // Memory stability (days)
  difficulty   Float     @default(5)    // Card difficulty 1-10
  lapses       Int       @default(0)    // Number of times forgotten
  state        CardState @default(NEW)  // Card learning state
  lastReview   DateTime?               // Timestamp of most recent review

  user         User      @relation(fields: [userId], references: [id])
  word         Word      @relation(fields: [wordId], references: [id])
  reviewLogs   ReviewLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, wordId])
}

enum CardState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

// 8. ReviewLog (per-review history for undo & statistics)
model ReviewLog {
  id            String    @id @default(cuid())
  userId        String
  wordId        String
  userWordId    String

  rating        Int       // 1=Again 2=Hard 3=Good 4=Easy
  state         CardState // State of the card at review time
  scheduledDays Int       @default(0) // Days until next review scheduled
  elapsedDays   Int       @default(0) // Days since last review
  timeSpent     Int       @default(0) // Time taken in milliseconds

  // Snapshot of FSRS state before this review (for undo)
  prevStability   Float   @default(0)
  prevDifficulty  Float   @default(5)
  prevStreak      Int     @default(0)
  prevNextReview  DateTime?
  prevState       CardState @default(NEW)
  prevEfactor     Float   @default(2.5)

  userWord  UserWord @relation(fields: [userWordId], references: [id], onDelete: Cascade)

  reviewedAt DateTime @default(now())

  @@index([userId])
  @@index([userWordId])
  @@index([reviewedAt])
}

// 6. Decks (User-created flashcard decks)
model Deck {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  languageCode String?
  isPublic    Boolean    @default(false)
  cardCount   Int        @default(0)
  
  user        User       @relation(fields: [userId], references: [id])
  deckCards   DeckCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 7. DeckCard (User-customisable card inside a deck – separate from dictionary Word)
model DeckCard {
  id             String    @id @default(cuid())
  deckId         String
  sourceWordId   String?   // optional reference to the dictionary Word it was imported from

  // User-customisable content
  term           String            // the word / character (required)
  meaning        Json?             // {"vi": "học", "en": "study", ...}
  pronunciation  String?           // phonetic / pinyin override
  imageUrl       String?           // custom image URL
  audioUrl       String?           // custom audio URL
  notes          String?           // personal notes
  position       Int       @default(0)

  // FSRS SRS scheduling (inline – deck belongs to one user)
  progress       Float     @default(0)
  streak         Int       @default(0)
  nextReview     DateTime  @default(now())
  efactor        Float     @default(2.5)
  stability      Float     @default(0)
  difficulty     Float     @default(5)
  lapses         Int       @default(0)
  state          CardState @default(NEW)
  lastReview     DateTime?

  deck           Deck  @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sourceWord     Word? @relation(fields: [sourceWordId], references: [id], onDelete: SetNull)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([deckId, term])
  @@index([deckId])
  @@index([deckId, nextReview])
}
